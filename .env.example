HOST=0.0.0.0
PORT=8787
AGENT_LIGHT_URL=http://127.0.0.1:8787

# Optional. Leave empty to use offline mock mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional local-agent integrations. They read private files under your home
# directory, so keep them disabled unless you understand the privacy impact.
ENABLE_HERMES_BINDING=0
ENABLE_CODEX_BINDING=0

# Android WebView shell build target. Replace with your computer's LAN IP.
SHELL_URL=http://YOUR_COMPUTER_LAN_IP:8787/display-landscape.html
